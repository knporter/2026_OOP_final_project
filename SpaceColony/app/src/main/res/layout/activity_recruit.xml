<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Recruit Crew Member"
        android:textColor="#64B5F6"
        android:textSize="22sp"
        android:textStyle="bold"
        android:padding="20dp"
        android:background="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crew Member Name"
                android:textColor="#90CAF9"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter name..."
                android:textColor="#212121"
                android:textColorHint="#546E7A"
                android:backgroundTint="#37474F"
                android:padding="12dp"
                android:inputType="textPersonName" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Specialization"
                android:textColor="#90CAF9"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgSpec"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton android:id="@+id/rbPilot"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="Pilot  (Skill:5  Res:4  Energy:20)"
                    android:textColor="#212121" android:buttonTint="#1565C0"
                    android:checked="true" />

                <RadioButton android:id="@+id/rbEngineer"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="Engineer  (Skill:6  Res:3  Energy:19)"
                    android:textColor="#212121" android:buttonTint="#1565C0" />

                <RadioButton android:id="@+id/rbMedic"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="Medic  (Skill:7  Res:2  Energy:18)"
                    android:textColor="#212121" android:buttonTint="#2E7D32" />

                <RadioButton android:id="@+id/rbScientist"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="Scientist  (Skill:8  Res:1  Energy:17)"
                    android:textColor="#212121" android:buttonTint="#6A1B9A" />

                <RadioButton android:id="@+id/rbSoldier"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="Soldier  (Skill:9  Res:0  Energy:16)"
                    android:textColor="#212121" android:buttonTint="#C62828" />
            </RadioGroup>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#1A2744"
                app:cardCornerRadius="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stats Preview"
                        android:textColor="#64B5F6"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skill: 5  Resistance: 4  Max Energy: 20  Color: Blue"
                        android:textColor="#B0BEC5"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancel"
            android:backgroundTint="#37474F"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnCreate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Recruit"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
